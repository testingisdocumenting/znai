{
  "id": "themed-box",
  "type": "include",
  "template": "plugins/themed-box-plugin.ftl",
  "arguments": {
    "freeForm": { "required": true },
    "severity": { "type": "string", "required": true, "limitValuesTo": ["info", "success", "warning"] },
    "tags": { "type": "list-of-string", "limitValuesTo": "$plugins/themed-box-tags.json" }
  }
}
